{
  "name": "baccarat-recorder",
  "version": "1.0.0",
  "description": "Baccarat Scorecard Recorder",
  "author": "Craig Hammond <hammondcraig@yahoo.com>",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win":   "electron-builder --win",
    "build:mac":   "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:all":   "electron-builder --win --mac --linux"
  },
  "build": {
    "appId": "com.baccaratrecorder.app",
    "productName": "Baccarat Recorder",
    "directories": { "output": "dist" },
    "files": ["main.js", "preload.js", "index.html", "renderer.js", "styles.css", "assets/"],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": [{ "target": "dmg", "arch": ["x64"] }],
      "icon": "assets/icon.icns",
      "category": "public.app-category.games"
    },
    "linux": {
      "target": [{ "target": "AppImage", "arch": ["x64"] }],
      "icon": "assets/icon.png",
      "category": "Game"
    },
    "icon": "assets/icon",
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}
